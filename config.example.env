# Foxentry Data Cleaner — example configuration
# Copy this file to "config.env" and fill in your API key. The file is kept
# ONLY on this computer and is never uploaded anywhere.

# --- Required -------------------------------------------------------------
# Your Foxentry API key (Settings -> API key in the Foxentry administration).
FOXENTRY_API_KEY=

# UI / report language: en or cs
LANGUAGE=en

# --- API ------------------------------------------------------------------
FOXENTRY_API_URL=https://api.foxentry.com
FOXENTRY_API_VERSION=2.1

# --- Processing -----------------------------------------------------------
# Default sample size offered for a custom-amount run.
TEST_SAMPLE=5
# Default country (CZ/SK/...) used only when "Add default country" is enabled.
DEFAULT_COUNTRY=CZ
# Input file encoding: auto, utf-8, utf-8-sig, cp1250, ...
INPUT_ENCODING=auto
# Output file encoding (utf-8-sig keeps diacritics readable in Excel).
OUTPUT_ENCODING=utf-8-sig
# Share of the rate limit the tool may use (0.0-1.0).
RATE_LIMIT_RESERVE=0.85
# HTTP timeout per request (seconds).
TIMEOUT=30
# Parallel requests.
CONCURRENCY=8
# Price-estimate currency: CZK, EUR_SK, EUR, PLN, USD
CURRENCY=CZK
# Open the wizard as a chromeless app window (Chrome/Edge/Brave) when available,
# otherwise a normal browser tab. Set to off to always use the default browser.
UI_APP_MODE=on

# --- Security -------------------------------------------------------------
# Quote cells starting with = + - @ so spreadsheets won't run them as formulas.
CSV_INJECTION_GUARD=on

# --- Logging --------------------------------------------------------------
# Request logging is OFF by default — nothing is written to logs/. You can
# enable it per run on the Order step; when on, the full request and response
# are saved (the API key in headers is masked). Set on here to always log.
LOG_REQUESTS=off
# Ask the API to echo the received request back (debugging only).
INCLUDE_REQUEST_DETAILS=off
# Auto-delete request logs older than N days at startup (0 = keep forever).
LOG_RETENTION_DAYS=7
# Human-readable application log (logs/app.log).
LOG_APP=on
